{
  "version": "6.17.0",
  "function": "compareRecommendationContext",
  "hardRequirements": [
    "recommendation applied",
    "target exercise present",
    "session after application",
    "session not already used for same recommendation",
    "sufficient completed set data"
  ],
  "softRequirements": [
    "same plan",
    "same training day",
    "current plan still matches"
  ],
  "scoreBehavior": {
    "90-100": "very comparable",
    "75-89": "regular evaluation allowed",
    "60-74": "inconclusive only",
    "below60": "no evaluation"
  },
  "blockingReasons": [
    "recommendation_not_applied",
    "exercise_changed",
    "session_before_application",
    "session_already_used",
    "insufficient_data"
  ]
}
